# Google Cloud API Configuration
# Get these values from: https://console.cloud.google.com/

# Google OAuth 2.0 Client ID (for Web application)
# Create OAuth 2.0 credentials in Google Cloud Console
# Authorized JavaScript origins: https://example.com, https://www.example.com, http://localhost:5173
# The app uses Google Identity Services (GIS) for authentication
VITE_GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_HERE

# Contact email shown on privacy-policy.html
VITE_CONTACT_EMAIL=your-email@example.com

# Google Form URL used by the feedback block in the footer
VITE_FEEDBACK_FORM_URL=https://forms.gle/your-form-id
